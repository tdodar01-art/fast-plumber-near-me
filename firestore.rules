rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public reads for plumbers and cities (needed for SSR)
    match /plumbers/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cities/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /reviews/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Leads — write from anyone (public click tracking), read admin only
    match /leads/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // Contact submissions — write from anyone, read admin only
    match /contactSubmissions/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // Business submissions — write from anyone, read/update/delete admin only
    match /businessSubmissions/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Plumber reports — write from anyone, read admin only
    match /plumberReports/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // API usage and rating snapshots — admin only
    match /apiUsage/{doc} {
      allow read, write: if request.auth != null;
    }
    match /ratingSnapshots/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
